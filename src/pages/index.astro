---
// Ridge & Route - Hiking Trail Discovery Website
// Single-page Astro homepage with Tailwind CSS v3
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Ridge & Route - Discover 200+ trails across New Hampshire's White Mountains. Live trail conditions, curated data, and community reports." />
  <title>Ridge & Route | New Hampshire Trail Discovery</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=optional" as="style" onload="this.onload=null;this.rel='stylesheet'" />
  <noscript><link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=optional" rel="stylesheet" /></noscript>
</head>
<body class="font-sans antialiased bg-light-gray text-dark-text">

  <!-- ========== UNIFIED HEADER + HERO SECTION ========== -->
  <div class="relative min-h-screen" style="background-color: #1a2332;">

    <!-- Background Image Layer -->
    <div class="absolute inset-0 z-0">
      <div
        class="absolute inset-0 bg-cover bg-center bg-no-repeat"
        style="background-image: url('https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=1600'); opacity: 0.6;"
        role="img"
        aria-label="Aerial view of New Hampshire mountain trails"
      ></div>
      <!-- Gradient overlay to blend image with header gradient -->
      <div
        class="absolute inset-0"
        style="background: linear-gradient(180deg, #1a2332 0%, rgba(30, 58, 74, 0.95) 25%, rgba(45, 90, 110, 0.7) 50%, rgba(45, 90, 110, 0.3) 75%, transparent 100%);"
      ></div>
    </div>

    <!-- Top Utility Bar -->
    <div class="relative z-10 border-b border-white/5" role="region" aria-label="Trail conditions at a glance">
      <div class="max-w-7xl mx-auto px-6 py-2">
        <div class="flex items-center justify-between text-xs" style="color: #ffffff;">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="12" cy="12" r="5" />
              <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" />
            </svg>
            <span>Littleton, NH · 54°F · Clear</span>
          </div>
          <div class="hidden sm:block">
            <span>Trail conditions updated daily</span>
          </div>
          <div class="hidden md:block">
            <span>Sunrise 6:02 AM · Sunset 7:41 PM</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Main Navigation -->
    <nav class="relative z-10" aria-label="Main navigation">
      <div class="max-w-7xl mx-auto px-6 py-5">
        <div class="flex items-center justify-between">
          <a href="#" class="text-2xl font-extrabold text-white tracking-tight">
            Ridge &amp; Route
          </a>
          <div class="hidden md:flex items-center gap-8">
            <a href="#" class="text-white hover:text-white/80 transition-colors text-sm font-medium underline-offset-4 hover:underline">Explore</a>
            <a href="#" class="text-white hover:text-white/80 transition-colors text-sm font-medium underline-offset-4 hover:underline">Trails</a>
            <a href="#" class="text-white hover:text-white/80 transition-colors text-sm font-medium underline-offset-4 hover:underline">Conditions</a>
            <a href="#" class="text-white hover:text-white/80 transition-colors text-sm font-medium underline-offset-4 hover:underline">Community</a>
            <a href="#" class="text-white hover:text-white/80 transition-colors text-sm font-medium underline-offset-4 hover:underline">Plan Your Hike</a>
          </div>
          <!-- Mobile menu button (decorative) -->
          <button class="md:hidden text-white" aria-label="Open menu" type="button">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>
    </nav>

    <!-- Hero Content -->
    <div class="relative z-10 flex flex-col items-center justify-center text-center px-6 pt-24 pb-40 min-h-[calc(100vh-140px)]">
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold text-white mb-6 tracking-tight">
        Find Your Next Summit
      </h1>
      <p class="text-lg sm:text-xl mb-10 max-w-2xl" style="color: #c8dde6;">
        Discover 200+ trails across New Hampshire's White Mountains
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <button type="button" class="px-8 py-4 bg-white text-forest-slate font-semibold rounded-full hover:bg-white/90 transition-all shadow-lg shadow-black/20">
          Explore Trails
        </button>
        <button type="button" class="px-8 py-4 border-2 border-white text-white font-semibold rounded-full hover:bg-white/10 transition-all">
          View Trail Map
        </button>
      </div>

      <!-- Floating Stats Strip -->
      <div class="absolute bottom-20 left-1/2 -translate-x-1/2 w-full max-w-4xl px-6">
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-8">
          <div class="backdrop-blur-md bg-white/10 border border-white/20 rounded-2xl px-6 py-4 text-center">
            <div class="text-2xl font-bold text-white">200+</div>
            <div class="text-sm" style="color: #c8dde6;">Trails</div>
          </div>
          <div class="backdrop-blur-md bg-white/10 border border-white/20 rounded-2xl px-6 py-4 text-center">
            <div class="text-2xl font-bold text-white">48</div>
            <div class="text-sm" style="color: #c8dde6;">Peaks Over 4,000ft</div>
          </div>
          <div class="backdrop-blur-md bg-white/10 border border-white/20 rounded-2xl px-6 py-4 text-center">
            <div class="text-2xl font-bold text-white">All</div>
            <div class="text-sm" style="color: #c8dde6;">Skill Levels Welcome</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Wave Divider -->
    <div class="absolute bottom-0 left-0 right-0 z-10" aria-hidden="true">
      <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto" preserveAspectRatio="none">
        <path d="M0 120L60 110C120 100 240 80 360 75C480 70 600 80 720 85C840 90 960 90 1080 85C1200 80 1320 70 1380 65L1440 60V120H1380C1320 120 1200 120 1080 120C960 120 840 120 720 120C600 120 480 120 360 120C240 120 120 120 60 120H0Z" fill="#f4f6f8"/>
      </svg>
    </div>
  </div>


  <!-- ========== SECTION 1: FEATURED TRAILS ========== -->
  <section class="bg-light-gray py-20 px-6" aria-labelledby="featured-trails-heading">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 id="featured-trails-heading" class="text-3xl sm:text-4xl font-bold text-dark-text mb-4">Featured Trails</h2>
        <div class="w-16 h-1 mx-auto rounded-full" style="background-color: #2d8a6e;" aria-hidden="true"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Trail 1 -->
        <div class="group relative h-[480px] rounded-3xl overflow-hidden shadow-xl">
          <img
            src="https://images.unsplash.com/photo-1551632811-561732d1e306?w=800"
            alt="Hikers ascending the Franconia Ridge Loop with snow-capped peaks in the background"
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-6" style="background: linear-gradient(to top, rgba(0,0,0,0.92) 0%, rgba(0,0,0,0.7) 60%, transparent 100%);">
            <span class="inline-block px-3 py-1 bg-red-600 text-white text-xs font-semibold rounded-full mb-3">Hard</span>
            <h3 class="text-2xl font-bold text-white mb-2">Franconia Ridge Loop</h3>
            <p class="text-sm text-white">8.9 mi · +3,900 ft elevation</p>
          </div>
        </div>

        <!-- Trail 2 -->
        <div class="group relative h-[480px] rounded-3xl overflow-hidden shadow-xl">
          <img
            src="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=800"
            alt="Sunset alpenglow over Mount Moosilauke summit with dramatic cloud sea below"
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-6" style="background: linear-gradient(to top, rgba(0,0,0,0.92) 0%, rgba(0,0,0,0.7) 60%, transparent 100%);">
            <span class="inline-block px-3 py-1 text-white text-xs font-semibold rounded-full mb-3" style="background-color: #92600a;">Moderate</span>
            <h3 class="text-2xl font-bold text-white mb-2">Mount Moosilauke</h3>
            <p class="text-sm text-white">7.4 mi · +2,500 ft elevation</p>
          </div>
        </div>

        <!-- Trail 3 -->
        <div class="group relative h-[480px] rounded-3xl overflow-hidden shadow-xl">
          <img
            src="https://images.unsplash.com/photo-1483728642387-6c3bdd6c93e5?w=800"
            alt="Lonesome Lake Trail with a lone mountain peak rising above the clouds"
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-6" style="background: linear-gradient(to top, rgba(0,0,0,0.92) 0%, rgba(0,0,0,0.7) 60%, transparent 100%);">
            <span class="inline-block px-3 py-1 text-white text-xs font-semibold rounded-full mb-3" style="background-color: #166534;">Easy</span>
            <h3 class="text-2xl font-bold text-white mb-2">Lonesome Lake Trail</h3>
            <p class="text-sm text-white">3.2 mi · +1,000 ft elevation</p>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ========== SECTION 2: TRAIL CONDITION DASHBOARD ========== -->
  <section class="relative py-24 px-6" style="background: linear-gradient(180deg, #f4f6f8 0%, #1a2332 8%, #1a2332 100%);" aria-labelledby="conditions-heading">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <p class="uppercase tracking-widest text-sm font-semibold mb-3" style="color: #1a6b52;">Real-Time Data</p>
        <h2 id="conditions-heading" class="text-3xl sm:text-4xl font-bold text-white">Live Trail Conditions</h2>
      </div>

      <div class="max-w-4xl mx-auto rounded-3xl p-8 shadow-2xl" style="background-color: #162030; border: 1px solid rgba(255,255,255,0.1);">

        <!-- Top Condition Indicators -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-10">
          <div class="flex items-center gap-3 rounded-xl p-4" style="background-color: #1e2d3d;">
            <div class="w-3 h-3 rounded-full bg-emerald-400" aria-hidden="true"></div>
            <div>
              <div class="text-xs uppercase tracking-wide" style="color: #a8c4d0;">Trail Status</div>
              <div class="text-white font-semibold">Open</div>
            </div>
          </div>
          <div class="flex items-center gap-3 rounded-xl p-4" style="background-color: #1e2d3d;">
            <svg class="w-5 h-5" style="color: #a8c4d0;" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />
            </svg>
            <div>
              <div class="text-xs uppercase tracking-wide" style="color: #a8c4d0;">Recent Rainfall</div>
              <div class="text-white font-semibold">0.2 in</div>
            </div>
          </div>
          <div class="flex items-center gap-3 rounded-xl p-4" style="background-color: #1e2d3d;">
            <svg class="w-5 h-5" style="color: #a8c4d0;" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
            <div>
              <div class="text-xs uppercase tracking-wide" style="color: #a8c4d0;">Wind</div>
              <div class="text-white font-semibold">12 mph NW</div>
            </div>
          </div>
        </div>

        <!-- Elevation Profile Chart -->
        <div class="mb-10">
          <div class="text-xs uppercase tracking-wide mb-4" style="color: #a8c4d0;">Elevation Profile — Franconia Ridge Loop</div>
          <div class="relative h-48 rounded-xl p-4 overflow-hidden" style="background-color: #1e2d3d;">
            <div class="absolute left-2 top-4 bottom-8 flex flex-col justify-between text-xs text-white/50" aria-hidden="true">
              <span>5,200 ft</span>
              <span>4,400 ft</span>
              <span>3,600 ft</span>
              <span>2,800 ft</span>
            </div>
            <div class="ml-16 h-full relative">
              <svg viewBox="0 0 400 120" class="w-full h-full" preserveAspectRatio="none" aria-label="Elevation profile chart for Franconia Ridge Loop showing peak at 5,249 feet" role="img">
                <line x1="0" y1="30" x2="400" y2="30" stroke="rgba(255,255,255,0.1)" stroke-width="1" />
                <line x1="0" y1="60" x2="400" y2="60" stroke="rgba(255,255,255,0.1)" stroke-width="1" />
                <line x1="0" y1="90" x2="400" y2="90" stroke="rgba(255,255,255,0.1)" stroke-width="1" />
                <path
                  d="M0 100 L20 95 L60 80 L100 60 L140 35 L180 20 L220 15 L260 25 L300 45 L340 70 L380 90 L400 100 L400 120 L0 120 Z"
                  fill="url(#elevationGradient)"
                />
                <path
                  d="M0 100 L20 95 L60 80 L100 60 L140 35 L180 20 L220 15 L260 25 L300 45 L340 70 L380 90 L400 100"
                  fill="none"
                  stroke="#2d8a6e"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
                <circle cx="220" cy="15" r="5" fill="#2d8a6e" />
                <defs>
                  <linearGradient id="elevationGradient" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="rgba(45, 138, 110, 0.4)" />
                    <stop offset="100%" stop-color="rgba(45, 138, 110, 0.05)" />
                  </linearGradient>
                </defs>
              </svg>
            </div>
            <div class="absolute bottom-0 left-16 right-4 flex justify-between text-xs text-white/50" aria-hidden="true">
              <span>0 mi</span>
              <span>2.2 mi</span>
              <span>4.5 mi</span>
              <span>6.7 mi</span>
              <span>8.9 mi</span>
            </div>
          </div>
        </div>

        <!-- Trail Metadata Grid -->
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
          <div class="text-center">
            <div class="text-xs uppercase tracking-wide mb-1" style="color: #a8c4d0;">Start Elevation</div>
            <div class="text-white font-semibold">2,800 ft</div>
          </div>
          <div class="text-center">
            <div class="text-xs uppercase tracking-wide mb-1" style="color: #a8c4d0;">Peak Elevation</div>
            <div class="text-white font-semibold">5,249 ft</div>
          </div>
          <div class="text-center">
            <div class="text-xs uppercase tracking-wide mb-1" style="color: #a8c4d0;">Total Distance</div>
            <div class="text-white font-semibold">8.9 mi</div>
          </div>
          <div class="text-center">
            <div class="text-xs uppercase tracking-wide mb-1" style="color: #a8c4d0;">Est. Time</div>
            <div class="text-white font-semibold">6–8 hrs</div>
          </div>
          <div class="text-center">
            <div class="text-xs uppercase tracking-wide mb-1" style="color: #a8c4d0;">Difficulty</div>
            <div class="text-white font-semibold">Hard</div>
          </div>
          <div class="text-center">
            <div class="text-xs uppercase tracking-wide mb-1" style="color: #a8c4d0;">Last Updated</div>
            <div class="text-white font-semibold">2 hrs ago</div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ========== SECTION 3: WHY RIDGE & ROUTE ========== -->
  <section class="relative py-24 px-6" style="background: linear-gradient(180deg, #1a2332 0%, #f4f6f8 15%, #f4f6f8 100%);" aria-labelledby="why-heading">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <p class="uppercase tracking-widest text-sm font-semibold mb-3" style="color: #1a6b52;">Why Choose Us</p>
        <h2 id="why-heading" class="text-3xl sm:text-4xl font-bold text-dark-text">Why Ridge &amp; Route</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12">
        <div class="text-center">
          <div class="text-5xl mb-5" aria-hidden="true">🗺️</div>
          <h3 class="text-xl font-bold text-dark-text mb-3">Curated Trail Data</h3>
          <p style="color: #4a6070;" class="leading-relaxed">Updated weekly by local hikers who know these mountains like home.</p>
        </div>
        <div class="text-center">
          <div class="text-5xl mb-5" aria-hidden="true">🌤️</div>
          <h3 class="text-xl font-bold text-dark-text mb-3">Live Weather &amp; Conditions</h3>
          <p style="color: #4a6070;" class="leading-relaxed">Real-time updates for every trailhead in the White Mountains.</p>
        </div>
        <div class="text-center">
          <div class="text-5xl mb-5" aria-hidden="true">📍</div>
          <h3 class="text-xl font-bold text-dark-text mb-3">Offline Trail Maps</h3>
          <p style="color: #4a6070;" class="leading-relaxed">Download detailed maps before you go — no signal required.</p>
        </div>
        <div class="text-center">
          <div class="text-5xl mb-5" aria-hidden="true">🏔️</div>
          <h3 class="text-xl font-bold text-dark-text mb-3">Community Reports</h3>
          <p style="color: #4a6070;" class="leading-relaxed">Hear from hikers who were just there — fresh beta, always.</p>
        </div>
      </div>
    </div>
  </section>


  <!-- ========== SECTION 4: COMMUNITY TESTIMONIALS ========== -->
  <section class="bg-light-gray py-24 px-6" aria-labelledby="testimonials-heading">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <p class="uppercase tracking-widest text-sm font-semibold mb-3" style="color: #1a6b52;">Community</p>
        <h2 id="testimonials-heading" class="text-3xl sm:text-4xl font-bold text-dark-text">What Hikers Are Saying</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <!-- Testimonial 1 -->
        <div class="text-center">
          <img
            src="https://i.pravatar.cc/60?img=1"
            alt="Portrait of Sarah M."
            class="w-16 h-16 rounded-full mx-auto mb-4 ring-4 ring-white shadow-lg"
          />
          <div class="text-sm font-bold text-dark-text uppercase tracking-wide mb-2">Sarah M.</div>
          <div class="text-lg mb-4" aria-label="5 out of 5 stars" style="color: #92600a;">★★★★★</div>
          <p style="color: #4a6070;" class="italic leading-relaxed mb-4">"The trail conditions feature saved our trip. We knew exactly what to expect before we even left the car."</p>
          <span class="inline-block px-3 py-1 text-xs font-semibold rounded-full" style="background-color: rgba(45,138,110,0.12); color: #1a6b52;">Franconia Ridge Loop</span>
        </div>

        <!-- Testimonial 2 -->
        <div class="text-center">
          <img
            src="https://i.pravatar.cc/60?img=2"
            alt="Portrait of Mike T."
            class="w-16 h-16 rounded-full mx-auto mb-4 ring-4 ring-white shadow-lg"
          />
          <div class="text-sm font-bold text-dark-text uppercase tracking-wide mb-2">Mike T.</div>
          <div class="text-lg mb-4" aria-label="5 out of 5 stars" style="color: #92600a;">★★★★★</div>
          <p style="color: #4a6070;" class="italic leading-relaxed mb-4">"Finally, an app that actually understands what hikers need. The offline maps are a game-changer."</p>
          <span class="inline-block px-3 py-1 text-xs font-semibold rounded-full" style="background-color: rgba(45,138,110,0.12); color: #1a6b52;">Mount Washington</span>
        </div>

        <!-- Testimonial 3 -->
        <div class="text-center">
          <img
            src="https://i.pravatar.cc/60?img=3"
            alt="Portrait of Emma R."
            class="w-16 h-16 rounded-full mx-auto mb-4 ring-4 ring-white shadow-lg"
          />
          <div class="text-sm font-bold text-dark-text uppercase tracking-wide mb-2">Emma R.</div>
          <div class="text-lg mb-4" aria-label="5 out of 5 stars" style="color: #92600a;">★★★★★</div>
          <p style="color: #4a6070;" class="italic leading-relaxed mb-4">"The community reports helped me find a hidden gem trail I never would have discovered otherwise."</p>
          <span class="inline-block px-3 py-1 text-xs font-semibold rounded-full" style="background-color: rgba(45,138,110,0.12); color: #1a6b52;">Lonesome Lake</span>
        </div>
      </div>
    </div>
  </section>


  <!-- ========== SECTION 5: CTA BANNER + FOOTER ========== -->
  <div style="background: linear-gradient(180deg, #f4f6f8 0%, #1e3a4a 8%, #1a2332 40%, #1a2332 100%);">

    <!-- CTA Section -->
    <section class="py-24 px-6 relative overflow-hidden" aria-labelledby="cta-heading">
      <div class="max-w-4xl mx-auto text-center relative z-10">
        <h2 id="cta-heading" class="text-4xl sm:text-5xl font-bold text-white mb-6">Ready to Hit the Trail?</h2>
        <p class="text-lg mb-10 max-w-2xl mx-auto" style="color: #a8c4d0;">
          Join thousands of hikers discovering New Hampshire's most beautiful trails with live conditions, detailed maps, and community insights.
        </p>
        <button type="button" class="inline-block px-10 py-4 bg-white text-forest-slate font-semibold rounded-full hover:bg-white/90 transition-all shadow-lg shadow-black/30">
          Start Exploring
        </button>
      </div>

      <!-- Mountain Silhouette -->
      <div class="absolute bottom-0 left-0 right-0" aria-hidden="true">
        <svg viewBox="0 0 1440 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto" preserveAspectRatio="none">
